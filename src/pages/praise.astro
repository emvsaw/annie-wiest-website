---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site';

const allTestimonials = await getCollection('testimonials');
---

<BaseLayout title={`Praise | ${site.name}`} description="What readers are saying about the Sacred Peaks Ranch series.">
  <section class="section">
    <div class="container">
      <div class="section-title">
        <span class="eyebrow">Reader Love</span>
        <h2>Praise</h2>
      </div>
      <div class="testimonial-grid">
        {allTestimonials.map(t => (
          <div class="testimonial-card">
            <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="quote">"{t.data.quote}"</p>
            <p class="attribution">&mdash; {t.data.source} ({t.data.bookTitle})</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
