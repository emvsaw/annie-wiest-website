---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title={`Privacy Policy | ${site.name}`}>
  <div class="container section">
    <h1>Privacy Policy</h1>
    <p>This page is a placeholder. Add your privacy policy here before the site goes live &mdash; covering what data is collected (e.g. newsletter sign-ups), how it's used, and readers' rights.</p>
  </div>
</BaseLayout>
