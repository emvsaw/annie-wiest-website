---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  description: site.bio[0],
  image: new URL(site.photo, Astro.site).toString(),
  url: Astro.site?.toString(),
  sameAs: [site.amazonAuthorLink, ...Object.values(site.socialLinks)].filter(Boolean),
  jobTitle: 'Author',
};
---

<BaseLayout title={`About | ${site.name}`} description={`About ${site.name}, author of sapphic romance.`} ogImage={site.photo}>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <section class="section">
    <div class="container about-grid">
      <div class="photo">
        <img src={site.photo} alt={site.name} loading="lazy" />
      </div>
      <div>
        <h1>About {site.name}</h1>
        {site.bio.map(paragraph => <p>{paragraph}</p>)}
        <a href={site.amazonAuthorLink} target="_blank" rel="noopener"><strong>Author page on Amazon</strong></a>
      </div>
    </div>
  </section>
</BaseLayout>
