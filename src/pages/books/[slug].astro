---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { slug: book.data.slug },
    props: { book: book.data },
  }));
}

const { book } = Astro.props;

const allTestimonials = await getCollection('testimonials');
const relatedPraise = allTestimonials.filter(
  t => t.data.bookTitle.trim().toLowerCase() === book.title.trim().toLowerCase()
);

const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: book.title,
  author: { '@type': 'Person', name: site.name },
  image: new URL(book.cover, Astro.site).toString(),
  description: book.blurb.split('\n\n')[0],
  isPartOfSeries: { '@type': 'CreativeWorkSeries', name: 'Sacred Peaks Ranch' },
  ...(book.buyLink && {
    offers: {
      '@type': 'Offer',
      url: book.buyLink,
      availability: book.preorder ? 'https://schema.org/PreOrder' : 'https://schema.org/InStock',
    },
  }),
};
---

<BaseLayout title={`${book.title} | ${site.name}`} description={book.blurb.split('\n\n')[0]} ogImage={book.cover}>
  <script type="application/ld+json" set:html={JSON.stringify(bookSchema)} />
  <div class="container book-detail">
    <div class="cover">
      <img src={book.cover} alt={book.title} loading="lazy" />
    </div>
    <div>
      <p class="series-label"><a href="/series/sacred-peaks-ranch-series/">{book.series}</a></p>
      <h1>{book.title}</h1>
      {book.buyLink && (
        <a href={book.buyLink} class="btn btn-primary" target="_blank" rel="noopener">{book.preorder ? 'Preorder Now' : 'Buy Now'}</a>
      )}

      <p class="eyebrow">About</p>
      <p class="blurb">{book.blurb}</p>

      {book.tropes && book.tropes.length > 0 && (
        <>
          <p class="eyebrow">In This Book</p>
          <ul class="trope-list">
            {book.tropes.map(t => <li>{t}</li>)}
          </ul>
        </>
      )}

      {book.heatLevel && (
        <p><strong>Heat Level:</strong> {book.heatLevel}</p>
      )}

      {book.contentNotes && (
        <p><strong>Content Notes:</strong> {book.contentNotes}</p>
      )}

      {book.seriesPromise && (
        <p><em>{book.seriesPromise}</em></p>
      )}

      {relatedPraise.length > 0 && (
        <>
          <p class="eyebrow">Praise For This Book</p>
          {relatedPraise.map(t => (
            <div class="testimonial-card" style="text-align:left; margin-bottom: 1rem;">
              <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              <p class="quote">"{t.data.quote}"</p>
              <p class="attribution">&mdash; {t.data.source}</p>
            </div>
          ))}
        </>
      )}
    </div>
  </div>
</BaseLayout>
